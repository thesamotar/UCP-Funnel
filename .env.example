# Copy to .env and fill in. .env is gitignored.

# --- LLM (ONE server-side key powers chat + routing for every account) -------
ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Provider selection — which LLM the node uses. Auto-detected from whichever
# key is set; set this only to force one when both keys are present.
# LLM_PROVIDER=anthropic         # "anthropic" | "gemini"

# Model selection — the node reads these; the browser sees only the name.
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase (database + auth) ------------------------------------------------
# Dashboard → Project Settings → API. Then run db/schema.sql in the SQL editor
# and seed with: .venv/bin/python -m db.seed   (see db/data_sourcing_mock.md)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy HS256 JWT secret (Project Settings → API → JWT Settings). Optional:
# if unset, tokens are verified against the project's public JWKS instead.
SUPABASE_JWT_SECRET=

# --- Razorpay (UPI payment step, TEST MODE) -----------------------------------
# dashboard.razorpay.com → Test Mode on → Account & Settings → API Keys →
# Generate Test Key. Use rzp_test_… keys only — never commit live keys.
# Without these, checkout fails loudly (503) — there is no mock-payment fallback.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
