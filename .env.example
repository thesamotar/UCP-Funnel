# Copy to .env and fill in your key(s). .env is gitignored.

ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# Provider selection — which LLM the node uses. Auto-detected from whichever
# key is set; set this only to force one when both keys are present.
# LLM_PROVIDER=anthropic         # "anthropic" | "gemini"

# Model selection — the node and the browser both read these (via /api/config).
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_MODEL=gemini-2.5-flash

# Hand the server keys to the browser UI (/api/config). Localhost convenience —
# leave unset on a public deployment (visitors paste their own key instead).
EXPOSE_CONFIG_KEYS=1
